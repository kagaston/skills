[private]
default:
    @just --list --unsorted

format:
    uv run ruff format .

lint:
    uv run ruff check --fix .

typecheck:
    uv run basedpyright src/

test *args:
    uv run pytest tests/ {{args}}

check: format lint typecheck test

# Run the server with stdio transport
run:
    uv run python src/mcp_server/server.py

# Run the server with HTTP transport on port 8000
run-http:
    MCP_TRANSPORT=http uv run python src/mcp_server/server.py --http

# Launch the interactive MCP inspector
dev:
    uv run fastmcp dev src/mcp_server/server.py:mcp
